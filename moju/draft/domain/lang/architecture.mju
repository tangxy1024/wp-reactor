// ---------------------------------------------------------------------------
// lang domain — module architecture
// Crate: wf-lang
// ---------------------------------------------------------------------------

module LangSchema {
  layer DataFusion
  owns WindowSchema, FieldDef, BaseType, FieldType

  responsible_for "WFS window schema definition — field types, base types, and schema structure"
}

module LangRule {
  layer DataFusion
  owns WflFile, UseDecl, PatternDecl, RuleDecl, MetaBlock, MetaEntry, PipelineStage, EventsBlock, EventDecl

  responsible_for "WFL rule file structure — rule declarations, metadata, events, and pipeline stages"
}

module LangMatch {
  layer DataFusion
  owns MatchClause, EachClause, KeyMapItem, MatchStep, StepBranch, PipeChain, CloseBlock, CloseMode, CloseTrigger, WindowMode

  responsible_for "WFL match clause AST — sequential pattern matching steps, close behavior, and window modes"
}

module LangExpr {
  layer DataFusion
  owns FieldSelector, FieldRef, CmpOp, BinOp, SystemVar, Expr

  responsible_for "WFL expression language — field references, comparison/arithmetic operators, and expression tree nodes"
}

module LangClauses {
  layer DataFusion
  owns ScoreExpr, EntityClause, YieldClause, YieldField, LimitsBlock, LimitItem

  responsible_for "WFL clause AST — scoring, entity extraction, yield output, and rate limiting"
}

module LangJoin {
  layer DataFusion
  owns JoinClause, JoinMode, JoinCondition

  responsible_for "WFL join clause AST — window join modes (snapshot, asof) and join conditions"
}

module LangConv {
  layer DataFusion
  owns ConvClause, ConvChain, ConvStep, SortKey

  responsible_for "WFL conv clause AST — post-match conversion chains (sort, top, dedup, where)"
}

module LangTest {
  layer DataFusion
  owns TestBlock, InputStmt, FieldAssign, ExpectStmt, HitAssert, EvalMode, PermutationMode

  responsible_for "WFL test contract — input/output assertions, evaluation modes, and permutation testing"
}

module LangChecker {
  layer DataFusion
  owns CheckError, Severity, LangReason

  responsible_for "Semantic validation, linting, and type-checking of WFL rules against schemas"
}

module LangCompile {
  layer DataFusion
  owns CompileRequest, RulePlan, BindPlan, MatchPlan, KeyMapPlan, WindowSpec, StepPlan, BranchPlan, AggPlan

  responsible_for "WFL compilation — parse and compile WFL rules into executable match plans"
}

module LangExePlan {
  layer DataFusion
  owns JoinPlan, JoinCondPlan, LimitsPlan, ExceedAction, RateSpec, EntityPlan, ScorePlan, YieldPlan, ConvPlan, ConvChainPlan, ConvOpPlan, SortKeyPlan

  responsible_for "WFL execution plans — compiled join, limits, entity, score, yield, and conv plans for runtime"
}

dependency_rule LangDeps {
  LangRule -> LangMatch
  LangRule -> LangExpr
  LangRule -> LangClauses
  LangRule -> LangJoin
  LangRule -> LangConv
  LangRule -> LangTest
  LangCompile -> LangRule
  LangCompile -> LangMatch
  LangCompile -> LangSchema
  LangChecker -> LangRule
  LangChecker -> LangSchema
  LangExePlan -> LangCompile
}
