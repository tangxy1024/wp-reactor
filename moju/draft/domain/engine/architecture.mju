// ---------------------------------------------------------------------------
// engine domain — module architecture
// Crate: wf-engine
// ---------------------------------------------------------------------------

module EventIngress {
  layer Interface
  owns DataSender, IncomingBatch, MemoryPressure, NewEvents

  responsible_for "Accept external data events and route them into the CEP engine"
}

module WindowManager {
  layer DataFusion
  owns Window, WindowParams, AppendOutcome, TimedBatch, WindowRegistry, WindowDef, Router, RouteReport, EvictReport

  responsible_for "Time-ordered event window buffer with eviction policy and stream-to-window routing"
}

module MatchEngine {
  layer DataFusion
  owns Event, Value, RuleExecutor, CepStateMachine, InstanceKey, Instance, StepState, BranchState, StepData, StepResult, MatchedContext, CloseOutput, CloseReason, CoreReason

  responsible_for "NFA-style state machine for sequential event pattern matching with close-mode lifecycle"
}

module AlertOutput {
  layer DataFusion
  owns OutputRecord, AlertOrigin

  responsible_for "Alert record production from match results with origin tagging"
}

module SinkDispatch {
  layer DataFusion
  owns SinkDispatcher, SinkRuntime

  responsible_for "Route OutputRecords to configured sinks with default and error fallback"
}

dependency_rule EngineDeps {
  EventIngress -> WindowManager
  EventIngress -> MatchEngine
  MatchEngine -> WindowManager
  MatchEngine -> AlertOutput
  AlertOutput -> SinkDispatch
  WindowManager -> SinkDispatch
}
