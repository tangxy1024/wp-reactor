// Verify config loading flow

verify LoadConfigOk for flow LoadConfig {
  given {
    ConfigLoadRequest.path = "wfusion.toml"
  }

  when ConfigLoadRequest

  expect {
    FusionConfig.sinks == "wfusion.toml"
  }
}

verify ResolveVarsOk for flow ResolveVars {
  given {
    TOMLString.raw = "${VAR}"
  }

  when TOMLString

  expect {
    ExpandedToml == ExpandedToml
  }
}
