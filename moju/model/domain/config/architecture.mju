// ---------------------------------------------------------------------------
// config domain — module architecture
// Crates: wf-config, wf-vars
// ---------------------------------------------------------------------------

module ConfigLoader {
  layer Application
  owns FusionConfig, FusionConfigLoader, FusionMode, RuntimeConfig, RawFusionConfigTree, RawFusionConfigChange, ResolvedConfigVar, ConfigLoadRequest, ConfigSnapshot, ConfigReason

  responsible_for "Load, validate, merge overlays, and resolve the wfusion.toml — core config lifecycle"
}

module VarResolver {
  layer DataFusion
  owns ConfigVarContext, ExpandedToml, SourceAtom, TracedValue, TOMLString, VarsReason

  responsible_for "TOML variable resolution with source provenance tracking (file, explicit, env, default)"
}

module WindowConfig {
  layer Application
  owns WindowDefaults, WindowOverride, WindowConfig, DistMode, EvictPolicy, LatePolicy, HumanDuration, ByteSize

  responsible_for "Window configuration — time-ordered buffer sizing, eviction policy, watermark, and lateness"
}

module SourceConfig {
  layer Application
  owns SourceConfig, TcpSourceConfig, FileSourceConfig, FileInputFormat

  responsible_for "Data source configuration — TCP listener and file ingest with format detection"
}

module LoggingMetrics {
  layer Application
  owns LoggingConfig, LogFormat, MetricsConfig, MetricsTopNConfig

  responsible_for "Logging and metrics configuration — log format/level, Prometheus export, and Top-N reporting"
}

module SinkConfig {
  layer Application
  owns SinkConfigBundle, FixedGroup, FlexGroup, ResolvedRouteSink, RouteFile, RouteGroup, RouteSink, ConnectorDefRaw, ConnectorTomlFile

  responsible_for "Sink configuration — route file parsing, group resolution, and connector definitions"
}

module ConfigChange {
  layer Application
  owns FusionReloadPlan, FusionChangeKind, FusionReloadDisposition, ClassifiedFusionConfigChange

  responsible_for "Configuration change detection, classification, and reload disposition planning"
}

dependency_rule ConfigDeps {
  ConfigLoader -> VarResolver
  ConfigLoader -> WindowConfig
  ConfigLoader -> SourceConfig
  ConfigLoader -> LoggingMetrics
  ConfigLoader -> SinkConfig
  ConfigLoader -> ConfigChange
}
