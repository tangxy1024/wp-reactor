// ---------------------------------------------------------------------------
// orchestra domain — module architecture
// Crates: wf-engine, wf-runtime
// ---------------------------------------------------------------------------

module EngineEntry {
  layer Interface
  owns Admin, Command, ConfigCommands, RunCli, RenderConfigCmd, OriginsCmd, VarsCmd, DiffCmd, ConfigLoadArgs, CompareConfigLoadArgs, PathFilterArgs, VarFilterArgs, ResolvedConfigLoad, EngineReason

  responsible_for "CLI entry point — parse commands (run, config render/origins/vars/diff), resolve config paths, dispatch to reactor"
}

module ReactorLifecycle {
  layer Application
  owns Reactor, BootstrapData, RunRule, RunRuleKind, ShutdownTrigger, RunCommand, ShutdownSignal, ConfigChange

  responsible_for "Reactor bootstrap, rule compilation, task group spawning, graceful shutdown, and signal handling"
}

module TaskOrchestration {
  layer Application
  owns TaskGroup

  responsible_for "Concurrent task spawning and supervision in dependency order: alert -> evictor -> rule -> receiver -> metrics"
}

module Receiver {
  layer Infrastructure
  owns Receiver

  responsible_for "Accept Arrow IPC streams over TCP or replay from files"
}

module SinkFactory {
  layer Infrastructure
  owns SinkFactoryRegistry

  responsible_for "Construct sink runtimes from connector kinds (file, arrow, syslog, tcp, blackhole)"
}

module RuntimeMetrics {
  layer Infrastructure
  owns RuntimeMetrics, Histogram, HistogramSnapshot, IntervalRates, IntervalSnapshot, TotalCounts, RunSummary, RuntimeReason

  responsible_for "Operational metrics collection — histograms, interval snapshots, top-N summaries, and Prometheus export"
}

module HotReload {
  layer Application
  owns PreparedRuleReload, ReloadPreparation

  responsible_for "Zero-downtime rule updates via atomic task swap with blocking detection"
}

dependency_rule OrchestraDeps {
  EngineEntry -> ReactorLifecycle
  ReactorLifecycle -> TaskOrchestration
  TaskOrchestration -> Receiver
  TaskOrchestration -> SinkFactory
  ReactorLifecycle -> HotReload
  ReactorLifecycle -> RuntimeMetrics
}
