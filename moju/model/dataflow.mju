// -- Cross-domain data pipeline — Arrow IPC ingress to alert output -------------
//
//  daemon mode:
//    TCP → Arrow IPC frame { tag, RecordBatch }
//    → route_batch(stream_name) → Router → WindowRegistry.find(stream_name)
//    → Window buffer → MatchEngine → OutputRecord → SinkDispatch

dataflow EventPipeline {
  node<flow> Orchestra.DataIngest
  node<flow> Engine.ProcessEvents

  edge<trigger> Orchestra.DataIngest -> Engine.ProcessEvents {
    data Engine.IncomingBatch
  }
}
