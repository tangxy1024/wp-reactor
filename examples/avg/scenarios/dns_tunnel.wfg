use "../schemas/dns.wfs"
use "../rules/dns_tunnel.wfl"

#[duration=10m]
scenario dns_tunnel_detect<seed=42> {
  traffic {
    stream dns_events gen 100/s
  }

  injection {
    hit<30%> dns_events {
      sip seq {
        use(resp_size=1200) with(3,1m)
      }
    }

    near_miss<10%> dns_events {
      sip seq {
        use(resp_size=200) with(2,1m)
      }
    }

    miss<60%> dns_events {
      sip seq {
        use(resp_size=60) with(1,30s)
      }
    }
  }

  expect {
    hit(dns_tunnel) >= 95%
    near_miss(dns_tunnel) <= 1%
    miss(dns_tunnel) <= 0.1%
  }
}
