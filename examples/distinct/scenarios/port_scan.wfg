use "../schemas/network.wfs"
use "../rules/port_scan.wfl"

#[duration=10m]
scenario port_scan_detect<seed=42> {
  traffic {
    stream conn_events gen 100/s
  }

  injection {
    hit<40%> conn_events {
      sip seq {
        use(action="syn") with(12,30s)
      }
    }

    near_miss<20%> conn_events {
      sip seq {
        use(action="syn") with(2,10s)
      }
    }

    miss<40%> conn_events {
      sip seq {
        use(action="login") with(1,10s)
      }
    }
  }

  expect {
    hit(port_scan) >= 80%
    near_miss(port_scan) <= 5%
    miss(port_scan) <= 0.5%
  }
}
